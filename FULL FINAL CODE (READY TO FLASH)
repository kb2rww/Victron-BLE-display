/**********************************************************************
 * ESP32‑2432S028R Victron SmartShunt Display
 * -------------------------------------------------------------
 * Layout:
 *   V: 12.84V   S: 12.66V
 *   I:-000.00A  P: 000W
 *   Used / Time
 *   Bottom SOC bar with % inside
 *
 * Style:
 *   Black background
 *   White text
 *   Only current + SOC bar use color
 **********************************************************************/

#include <TFT_eSPI.h>
#include <XPT2046_Touchscreen.h>
#include <NimBLEDevice.h>
#include <AESLib.h>

/******************** VICRON DEVICE DETAILS *************************/

static NimBLEAddress victronAddress("c7:99:4b:5e:37:f5");

uint8_t victronKey[16] = {
  0xF8, 0x2C, 0x27, 0xC1,
  0xB4, 0xD8, 0xFE, 0x78,
  0x80, 0x2C, 0xF5, 0x2E,
  0x39, 0xB6, 0x4D, 0xA1
};

/******************** HARDWARE PINS *********************************/

#define TFT_BL     21
#define TOUCH_CS  33
#define TOUCH_IRQ 36

/******************** OBJECTS ***************************************/

TFT_eSPI tft;
XPT2046_Touchscreen ts(TOUCH_CS, TOUCH_IRQ);
AESLib aes;

NimBLEClient* client;
NimBLERemoteCharacteristic* notifyChar;

/******************** GLOBAL STATE **********************************/

bool nightMode = false;
unsigned long lastRefresh = 0;

/******************** BATTERY DATA **********************************/

struct VictronData {
  float voltage;         // House battery
  float starterVoltage;  // Starter battery
  float current;
  float power;
  float soc;
  float usedAh;
  int   ttg;             // minutes
};

VictronData battery;

/******************** VICTRON FIELD IDS *****************************/

#define V_VOLT     0x04
#define V_CURR     0x05
#define V_USED     0x08
#define V_SOC      0x0A
#define V_STARTER  0x0E
#define V_TTG      0x0F

/******************** UI LAYOUT *************************************/

#define SOC_BAR_X 10
#define SOC_BAR_Y 210
#define SOC_BAR_W 300
#define SOC_BAR_H 22

#define NIGHT_BTN_X 260
#define NIGHT_BTN_Y 5
#define NIGHT_BTN_W 50
#define NIGHT_BTN_H 20

/******************** AES DECRYPT ***********************************/

void decrypt(uint8_t* data, size_t len) {
  uint8_t iv[16] = {0};
  aes.decrypt(data, len, victronKey, iv);
}

