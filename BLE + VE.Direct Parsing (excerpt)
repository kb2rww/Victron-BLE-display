void pollVEDirect() {
  if (!Serial2.available()) return;
  String line = Serial2.readStringUntil('\n');
  vedLines++;

  if (line.startsWith("V\t")) battery.V = line.substring(2).toInt() / 1000.0;
  if (line.startsWith("VS\t")) battery.Vs = line.substring(3).toInt() / 1000.0;
  if (line.startsWith("I\t")) {
    battery.I = line.substring(2).toInt() / 1000.0;
    battery.P = battery.I * battery.V;
  }
  if (line.startsWith("SOC\t")) battery.soc = line.substring(4).toInt() / 10.0;
}
