/********************************************************************
 * ESP32‑2432S028R Victron Monitor Demo
 * ---------------------------------------------------------------
 * Features:
 *  - TFT display (ILI9341)
 *  - Touchscreen night‑mode toggle
 *  - Color‑coded current (green = charge, red = discharge)
 *  - SOC bar graph
 *  - Backlight dimming
 ********************************************************************/

#include <TFT_eSPI.h>              // TFT display driver
#include <XPT2046_Touchscreen.h>   // Touch controller driver

/******************* TFT & TOUCH PINS ******************************/

#define TFT_BL   21      // Backlight control pin
#define TOUCH_CS 33      // Touch controller chip‑select
#define TOUCH_IRQ 36     // Touch interrupt (optional)

/******************* OBJECTS **************************************/

TFT_eSPI tft;                                 // Display object
XPT2046_Touchscreen ts(TOUCH_CS, TOUCH_IRQ);  // Touch object

/******************* GLOBAL STATE *********************************/

bool nightMode = false;          // Current UI theme
unsigned long lastRefresh = 0;   // Display refresh timer

/******************* VICRTON DATA MODEL ****************************/
// These values will normally be updated by BLE decoding

struct VictronData {
  float voltage;      // Battery voltage (V)
  float current;      // Battery current (A)
  float power;        // Power (W)
  float soc;          // State of Charge (%)
  float consumedAh;   // Consumed Ah
  int   timeToGo;     // Minutes remaining
};

VictronData battery;

/******************* COLOR PALETTE ********************************/
// Day colors
#define DAY_TEXT    TFT_WHITE
#define DAY_GREEN   TFT_GREEN
#define DAY_RED     TFT_RED
#define DAY_YELLOW  TFT_YELLOW

// Night colors (dimmed)
#define NIGHT_TEXT    0x7BEF   // Dim gray
#define NIGHT_GREEN   0x03E0   // Dark green
#define NIGHT_RED     0x7800   // Dark red
#define NIGHT_YELLOW  0x4208   // Dark yellow

/******************* UI HELPERS ***********************************/
// These automatically return correct colors depending on mode

uint16_t uiText()   { return nightMode ? NIGHT_TEXT   : DAY_TEXT; }
uint16_t uiGreen()  { return nightMode ? NIGHT_GREEN  : DAY_GREEN; }
uint16_t uiRed()    { return nightMode ? NIGHT_RED    : DAY_RED; }
uint16_t uiYellow() { return nightMode ? NIGHT_YELLOW : DAY_YELLOW; }

/******************* SOC BAR POSITION *****************************/

#define SOC_BAR_X 10
#define SOC_BAR_Y 150
#define SOC_BAR_W 300
#define SOC_BAR_H 24

/******************* NIGHT MODE BUTTON ****************************/

#define NIGHT_BTN_X 260
#define NIGHT_BTN_Y 5
#define NIGHT_BTN_W 50
#define NIGHT_BTN_H 20

/******************* INITIALIZATION *******************************/

void setup() {
  Serial.begin(115200);          // Enable serial debugging

  // --- TFT DISPLAY INIT ---
  tft.init();                    // Initialize TFT
  tft.setRotation(1);            // Landscape mode
  tft.fillScreen(TFT_BLACK);     // Clear screen

  // --- BACKLIGHT PWM ---
  ledcAttachPin(TFT_BL, 0);      // Attach backlight pin to PWM channel 0
  ledcSetup(0, 5000, 8);         // 5 kHz PWM, 8‑bit duty
  setBrightness();               // Set initial brightness

  // --- TOUCH INIT ---
  ts.begin();                    // Initialize touch controller
  ts.setRotation(1);             // Match display rotation

  // --- DRAW STATIC UI ---
  drawHeader();

  // --- DEMO DATA (Replace with BLE later) ---
  battery.voltage = 12.84;
  battery.current = -5.23;
  battery.power = -67;
  battery.soc = 82.0;
  battery.consumedAh = 31.2;
  battery.timeToGo = 225;
}

/******************* MAIN LOOP ************************************/

void loop() {
  handleTouch();     // Check for taps
  loopDisplay();     // Update display once per second
}

/******************* DISPLAY FUNCTIONS ****************************/

void drawHeader() {
  tft.fillRect(0, 0, 320, 30, TFT_DARKGREY);
  tft.setTextFont(2);
  tft.setTextColor(TFT_WHITE, TFT_DARKGREY);
  tft.setCursor(10, 8);
  tft.print("Victron SmartShunt");

  drawNightIcon();   // Draw moon/sun icon
}

/******************* BATTERY DATA DRAW ****************************/

void drawBatteryData() {
  tft.setTextFont(4);
  tft.setTextColor(uiText(), TFT_BLACK);

  tft.setCursor(10, 40);
  tft.printf("V: %.2f V", battery.voltage);

  drawCurrent(battery.current);

  tft.setCursor(10, 120);
  tft.printf("P: %.0f W", battery.power);

  drawSOCBar(battery.soc);

  tft.setCursor(10, 190);
  tft.printf("Used: %.1f Ah", battery.consumedAh);

  int h = battery.timeToGo / 60;
  int m = battery.timeToGo % 60;

  tft.setCursor(10, 230);
  tft.printf("Time: %dh %dm", h, m);
}

/******************* CURRENT DISPLAY ******************************/

void drawCurrent(float current) {
  uint16_t color = uiText();

  if (current > 0.2) color = uiGreen();   // Charging
  if (current < -0.2) color = uiRed();    // Discharging

  tft.setTextColor(color, TFT_BLACK);
  tft.setCursor(10, 80);
  tft.printf("I: %.2f A", current);
}

/******************* SOC BAR **************************************/

void drawSOCBar(float soc) {
  soc = constrain(soc, 0, 100);

  uint16_t fill = (soc < 20) ? uiRed() :
                  (soc < 50) ? uiYellow() : uiGreen();

  tft.drawRect(SOC_BAR_X, SOC_BAR_Y, SOC_BAR_W, SOC_BAR_H, uiText());

  tft.fillRect(
    SOC_BAR_X + 1,
    SOC_BAR_Y + 1,
    (SOC_BAR_W - 2) * soc / 100.0,
    SOC_BAR_H - 2,
    fill
  );

  tft.setTextFont(2);
  tft.setTextColor(uiText(), TFT_BLACK);
  tft.setCursor(SOC_BAR_X + 115, SOC_BAR_Y + 6);
  tft.printf("%.1f %%", soc);
}

/******************* DISPLAY REFRESH ******************************/

void loopDisplay() {
  if (millis() - lastRefresh < 1000) return;

  tft.fillRect(0, 30, 320, 290, TFT_BLACK);
  drawBatteryData();

  lastRefresh = millis();
}

/******************* TOUCH HANDLING *******************************/

void handleTouch() {
  if (!ts.touched()) return;

  TS_Point p = ts.getPoint();

  int x = map(p.x, 200, 3800, 0, 320);
  int y = map(p.y, 200, 3800, 0, 240);

  if (x >= NIGHT_BTN_X && x <= NIGHT_BTN_X + NIGHT_BTN_W &&
      y >= NIGHT_BTN_Y && y <= NIGHT_BTN_Y + NIGHT_BTN_H) {
    toggleNightMode();
    delay(300);  // debounce
  }
}

/******************* NIGHT ICON **********************************/

void drawNightIcon() {
  tft.fillRect(NIGHT_BTN_X, NIGHT_BTN_Y, NIGHT_BTN_W, NIGHT_BTN_H, TFT_DARKGREY);
  tft.drawRect(NIGHT_BTN_X, NIGHT_BTN_Y, NIGHT_BTN_W, NIGHT_BTN_H, TFT_WHITE);
  tft.setTextFont(2);
  tft.setCursor(NIGHT_BTN_X + 8, NIGHT_BTN_Y + 5);
  tft.print(nightMode ? "NITE" : "DAY ");
}

/******************* NIGHT MODE TOGGLE ****************************/

void toggleNightMode() {
  nightMode = !nightMode;
  setBrightness();
  tft.fillScreen(TFT_BLACK);
  drawHeader();
}

/******************* BACKLIGHT CONTROL ****************************/

void setBrightness() {
  ledcWrite(0, nightMode ? 40 : 200);
}
